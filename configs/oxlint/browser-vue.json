{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["./base.json"],
  "plugins": ["typescript", "import", "promise"],
  "rules": {
    "no-console": "warn",
    "import/no-cycle": "deny",
    "import/no-self-import": "deny",
    "typescript/restrict-template-expressions": ["deny", { "allowNever": true }]
  },
  "env": {
    "browser": true
  }
}
